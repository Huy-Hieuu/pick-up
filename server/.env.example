# Application
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info,pickup_server=debug

# Database
DATABASE_URL=postgres://pickup:pickup@localhost:5432/pickup

# Redis
REDIS_URL=redis://localhost:6379
REDIS_OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Email / SMTP (via lettre)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_MAIL_FROM=noreply@pickup.app
SMTP_MAIL_FROM_NAME=PickUp Application
SMTP_USE_TLS=true

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# SMS (eSMS)
SMS_API_KEY=
SMS_SECRET_KEY=
SMS_SENDER=PickUp

# Momo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ZaloPay
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=pickup-media
