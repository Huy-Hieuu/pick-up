        {
          "name": "PATCH /auth/me",
          "request": {
            "method": "PATCH",
            "url": "http://localhost:8080/auth/me",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer REPLACE_WITH_ACCESS_TOKEN" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"John Updated\",\n  \"avatar_url\": \"https://example.com/new-avatar.jpg\"\n}"
            }
          }
        }
