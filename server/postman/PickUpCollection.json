{
  "info": {
    "name": "PickUpCollection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "PickUp API Collection for testing"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/health",
            "description": "Health check"
          }
        }
      ]
    },
    {
