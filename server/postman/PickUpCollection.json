          "request": {
            "method": "POST",
            "url": "http://localhost:8080/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0909123123\",\n  \"email\": \"test@example.com\",\n  \"display_name\": \"John Doe\",\n  \"avatar_url\": \"https://example.com/avatar.jpg\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "url": "http://localhost:8080/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
